{
  "name": "booking-job-app",
  "version": "1.0.0",
  "description": "Booking Job REST API",
  "type": "module",
  "engines": {
    "node": ">=18.19.0"
  },
  "imports": {
    "#src/*": "./src/*.js",
    "#configs/*": "./src/configs/*.js",
    "#constants/*": "./src/common/constants/*.js",
    "#controllers/*": "./src/controllers/*.js",
    "#services/*": "./src/services/*.js",
    "#repositories/*": "./src/repositories/*.js",
    "#models/*": "./src/models/*.js",
    "#schemas/*": "./src/schemas/*.js",
    "#common-schemas/*": "./src/common/schemas/*.js",
    "#utils/*": "./src/utils/*.js",
    "#test/*": "./test/*"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "create-admin": "node scripts/create-admin.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "npm test -- test/unit",
    "test:integration": "npm test -- test/integration"
  },
  "dependencies": {
    "@fastify/autoload": "^5.10.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.1.0",
    "awilix": "^10.0.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "overrides": {
    "fast-uri": "^3.1.3"
  }
}
