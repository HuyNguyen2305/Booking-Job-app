PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/booking_job_app
BUSINESS_TZ=Asia/Ho_Chi_Minh
# How often (ms) the server auto-completes past-due CONFIRMED bookings. Default: 5 minutes.
AUTO_COMPLETE_INTERVAL_MS=300000
# Required when NODE_ENV=production (auth is bypassed otherwise, so this is unused in dev/test).
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
